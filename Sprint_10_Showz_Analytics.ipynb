    "\\n",
    "# ROMI por fuente\\n",
    "colors = ['green' if x > 0 else 'red' for x in romi.values]\\n",
    "axes[0,0].bar(romi.index.astype(str), romi.values, color=colors)\\n",
    "axes[0,0].set_title('ROMI por Fuente de Adquisición', fontsize=12, fontweight='bold')\\n",
