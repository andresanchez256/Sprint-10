# ==================== 1. CARGA Y LIMPIEZA DE DATOS ====================
print("\n📂 1. CARGANDO DATOS...")

def load_and_clean_data():
    """Carga y limpia los datasets"""
    
    # Cargar datos
    visits = pd.read_csv('/datasets/visits_log_us.csv')
    orders = pd.read_csv('/datasets/orders_log_us.csv')
    costs = pd.read_csv('/datasets/costs_us.csv')
    
    print(f"   ✓ Visits: {visits.shape[0]:,} registros")
    print(f"   ✓ Orders: {orders.shape[0]:,} registros")
    print(f"   ✓ Costs: {costs.shape[0]:,} registros")
    
    # Limpiar visits
    visits_clean = visits.copy()
    visits_clean['Start Ts'] = pd.to_datetime(visits_clean['Start Ts'])
    visits_clean['End Ts'] = pd.to_datetime(visits_clean['End Ts'])
    visits_clean['duration_min'] = (visits_clean['End Ts'] - visits_clean['Start Ts']).dt.total_seconds() / 60
    
    # Eliminar sesiones inválidas
    invalid_sessions = (visits_clean['duration_min'] < 0) | (visits_clean['duration_min'] > 1440)
    visits_clean = visits_clean[~invalid_sessions]
    
    # Agregar columnas temporales
    visits_clean['visit_date'] = visits_clean['Start Ts'].dt.date
    visits_clean['visit_month'] = visits_clean['Start Ts'].dt.to_period('M')
    visits_clean['visit_week'] = visits_clean['Start Ts'].dt.to_period('W')
    visits_clean['visit_hour'] = visits_clean['Start Ts'].dt.hour
    
    # Limpiar orders
    orders_clean = orders.copy()
    orders_clean['Buy Ts'] = pd.to_datetime(orders_clean['Buy Ts'])
    orders_clean['buy_date'] = orders_clean['Buy Ts'].dt.date
    orders_clean['buy_month'] = orders_clean['Buy Ts'].dt.to_period('M')
    
    # Limpiar costs
    costs_clean = costs.copy()
    costs_clean['dt'] = pd.to_datetime(costs_clean['dt'])
    costs_clean['cost_date'] = costs_clean['dt'].dt.date
    costs_clean['cost_month'] = costs_clean['dt'].dt.to_period('M')
    
    print(f"\n   ✅ Datos limpios y preparados")
    print(f"   • Visits válidas: {len(visits_clean):,}")
    print(f"   • Usuarios únicos: {visits_clean['Uid'].nunique():,}")
    print(f"   • Pedidos totales: {len(orders_clean):,}")
    print(f"   • Revenue total: ${orders_clean['Revenue'].sum():,.2f}")
    print(f"   • Gasto total: ${costs_clean['costs'].sum():,.2f}")
    
    return visits_clean, orders_clean, costs_clean

# Ejecutar carga
visits_clean, orders_clean, costs_clean = load_and_clean_data()

# ==================== 2. ANÁLISIS DE VISITAS ====================
print("\n" + "="*80)
print("📊 2. ANÁLISIS DE VISITAS")
print("="*80)

def analyze_visits(visits_clean):
    """Analiza métricas de visitas"""
    
    # Usuarios activos
    daily_users = visits_clean.groupby('visit_date')['Uid'].nunique()
    weekly_users = visits_clean.groupby('visit_week')['Uid'].nunique()
    monthly_users = visits_clean.groupby('visit_month')['Uid'].nunique()
    daily_sessions = visits_clean.groupby('visit_date').size()
    
    print(f"\n📈 Usuarios Activos:")
    print(f"   • Promedio diario: {daily_users.mean():.0f}")
    print(f"   • Promedio semanal: {weekly_users.mean():.0f}")
    print(f"   • Promedio mensual: {monthly_users.mean():.0f}")
    
    # Duración de sesiones
    print(f"\n⏱️ Duración de Sesiones:")
    print(f"   • Promedio: {visits_clean['duration_min'].mean():.1f} minutos")
    print(f"   • Mediana: {visits_clean['duration_min'].median():.1f} minutos")
    
    # Frecuencia de retorno
    user_session_count = visits_clean.groupby('Uid').size()
    returning_users = (user_session_count > 1).sum()
    pct_returning = (returning_users / len(user_session_count)) * 100
    
    print(f"\n🔄 Retorno de Usuarios:")
    print(f"   • Usuarios que regresan: {returning_users:,} ({pct_returning:.1f}%)")
    print(f"   • Sesiones promedio por usuario: {user_session_count.mean():.2f}")
    
    return daily_users, weekly_users, monthly_users, daily_sessions

daily_users, weekly_users, monthly_users, daily_sessions = analyze_visits(visits_clean)

# ==================== 3. ANÁLISIS DE VENTAS ====================
print("\n" + "="*80)
print("💰 3. ANÁLISIS DE VENTAS")
print("="*80)

def analyze_sales(visits_clean, orders_clean):
    """Analiza métricas de ventas y LTV"""
    
    # Tiempo hasta primera compra
    first_visit = visits_clean.groupby('Uid')['visit_date'].min().reset_index()
    first_visit.columns = ['Uid', 'first_visit_date']
    first_purchase = orders_clean.groupby('Uid')['buy_date'].min().reset_index()
    first_purchase.columns = ['Uid', 'first_purchase_date']
    
    user_journey = first_visit.merge(first_purchase, on='Uid', how='inner')
    user_journey['first_visit_date'] = pd.to_datetime(user_journey['first_visit_date'])
    user_journey['first_purchase_date'] = pd.to_datetime(user_journey['first_purchase_date'])
    user_journey['days_to_purchase'] = (user_journey['first_purchase_date'] - user_journey['first_visit_date']).dt.days
    
    print(f"\n⏰ Tiempo hasta primera compra:")
    print(f"   • Promedio: {user_journey['days_to_purchase'].mean():.1f} días")
    print(f"   • Mediana: {user_journey['days_to_purchase'].median():.0f} días")
    
    # Estadísticas de pedidos
    conversion_0d = (user_journey['days_to_purchase'] == 0).sum()
    conversion_1d = (user_journey['days_to_purchase'] == 1).sum()
    conversion_2_7d = ((user_journey['days_to_purchase'] >= 2) & (user_journey['days_to_purchase'] <= 7)).sum()
    
    print(f"\n📊 Distribución de conversión:")
    print(f"   • Mismo día: {conversion_0d} usuarios")
    print(f"   • 1 día: {conversion_1d} usuarios")
    print(f"   • 2-7 días: {conversion_2_7d} usuarios")
    
    # LTV
    user_revenue = orders_clean.groupby('Uid')['Revenue'].sum().reset_index()
    user_revenue.columns = ['Uid', 'total_revenue']
    
    print(f"\n💰 LTV (Life Time Value):")
    print(f"   • Promedio: ${user_revenue['total_revenue'].mean():.2f}")
    print(f"   • Mediana: ${user_revenue['total_revenue'].median():.2f}")
    
    return user_journey, user_revenue

user_journey, user_revenue = analyze_sales(visits_clean, orders_clean)

# ==================== 4. ANÁLISIS DE MARKETING ====================
print("\n" + "="*80)
print("🎯 4. ANÁLISIS DE MARKETING")
print("="*80)

def analyze_marketing(visits_clean, orders_clean, costs_clean, user_revenue):
    """Analiza métricas de marketing: CAC y ROMI"""
    
    # Identificar fuente de adquisición de cada usuario
    first_source = visits_clean.sort_values('Start Ts').groupby('Uid').first().reset_index()[['Uid', 'Source Id']]
    first_source.columns = ['Uid', 'acquisition_source']
    
    # Clientes por fuente
    customers = orders_clean[['Uid']].drop_duplicates()
    customers_by_source = first_source.merge(customers, on='Uid', how='inner')
    new_customers_by_source = customers_by_source.groupby('acquisition_source').size()
    
    # Gastos por fuente
    source_costs = costs_clean.groupby('source_id')['costs'].sum()
    
    # CAC por fuente
    cac_by_source = source_costs / new_customers_by_source
    cac_by_source = cac_by_source.fillna(0)
    
    print(f"\n💰 CAC (Costo de Adquisición):")
    print(f"   • Promedio general: ${(source_costs.sum() / len(customers_by_source)):.2f}")
    print(f"\n   Por fuente:")
    for source in cac_by_source.sort_values().index:
        print(f"   • Source {source}: ${cac_by_source[source]:.2f}")
    
    # Revenue por fuente
    source_revenue = customers_by_source.merge(user_revenue, on='Uid', how='left')
    source_revenue = source_revenue.groupby('acquisition_source')['total_revenue'].sum()
    
    # ROMI por fuente
    romi_by_source = (source_revenue - source_costs) / source_costs * 100
    
    # LTV por fuente
    source_ltv = source_revenue / new_customers_by_source
    
    # Ratio LTV/CAC
    ltv_cac_ratio = source_ltv / cac_by_source
    
    print(f"\n📊 ROMI (Return on Marketing Investment):")
    print(f"   • Promedio general: {((source_revenue.sum() - source_costs.sum()) / source_costs.sum() * 100):.1f}%")
    print(f"\n   Por fuente:")
    for source in romi_by_source.sort_values(ascending=False).index:
        print(f"   • Source {source}: ROMI = {romi_by_source[source]:.1f}%, LTV/CAC = {ltv_cac_ratio[source]:.2f}")
    
    # Crear DataFrame resumen
    summary = pd.DataFrame({
        'Gasto_Total': source_costs,
        'Clientes': new_customers_by_source,
        'Revenue_Total': source_revenue,
        'CAC': cac_by_source,
        'LTV': source_ltv,
        'ROMI_%': romi_by_source,
        'LTV/CAC': ltv_cac_ratio
    }).round(2)
    
    return summary, romi_by_source, ltv_cac_ratio

summary, romi_by_source, ltv_cac_ratio = analyze_marketing(visits_clean, orders_clean, costs_clean, user_revenue)

# ==================== 5. RECOMENDACIONES ====================
print("\n" + "="*80)
print("💡 5. RECOMENDACIONES PARA MARKETING")
print("="*80)

def generate_recommendations(summary, romi_by_source, ltv_cac_ratio):
    """Genera recomendaciones basadas en el análisis"""
    
    # Identificar fuentes rentables (ROMI > 20% y LTV/CAC > 2)
    profitable_sources = summary[(summary['ROMI_%'] > 20) & (summary['LTV/CAC'] > 2)]
    
    # Identificar fuentes no rentables (ROMI < 0)
    unprofitable_sources = summary[summary['ROMI_%'] < 0]
    
    print("\n✅ FUENTES RECOMENDADAS PARA INVERTIR:")
    if not profitable_sources.empty:
        for source in profitable_sources.index:
            print(f"\n   🎯 Source {source}:")
            print(f"      • ROMI: {profitable_sources.loc[source, 'ROMI_%']:.1f}%")
            print(f"      • LTV/CAC: {profitable_sources.loc[source, 'LTV/CAC']:.2f}")
            print(f"      • Clientes adquiridos: {profitable_sources.loc[source, 'Clientes']:.0f}")
    else:
        print("   No se encontraron fuentes altamente rentables")
    
    print("\n⚠️ FUENTES PARA REDUCIR INVERSIÓN:")
    if not unprofitable_sources.empty:
        for source in unprofitable_sources.index:
            print(f"\n   • Source {source}: ROMI = {unprofitable_sources.loc[source, 'ROMI_%']:.1f}%")
    else:
        print("   Todas las fuentes son rentables")
    
    # Recomendaciones específicas
    print("\n📝 RECOMENDACIONES ESTRATÉGICAS:")
    
    # Mejor fuente por ROMI
    best_romi = romi_by_source.idxmax() if not romi_by_source.empty else None
    if best_romi:
        print(f"\n   1. AUMENTAR INVERSIÓN en Source {best_romi}:")
        print(f"      • Mayor ROMI del mercado ({romi_by_source[best_romi]:.1f}%)")
        print(f"      • Excelente retorno sobre la inversión")
    
    # Mejor fuente por LTV/CAC
    best_ratio = ltv_cac_ratio.idxmax() if not ltv_cac_ratio.empty else None
    if best_ratio and best_ratio != best_romi:
        print(f"\n   2. OPTIMIZAR Source {best_ratio}:")
        print(f"      • Mejor ratio LTV/CAC ({ltv_cac_ratio[best_ratio]:.2f})")
        print(f"      • Alta eficiencia en adquisición")
    
    print("\n   3. ESTRATEGIAS GENERALES:")
    print("      • Enfocar campañas en primeros 7 días post-visita")
    print("      • Implementar retargeting para usuarios que no convirtieron")
    print("      • Optimizar experiencia en dispositivos móviles")
    print("      • Monitorear CAC mensualmente para detectar desviaciones")

generate_recommendations(summary, romi_by_source, ltv_cac_ratio)

# ==================== 6. VISUALIZACIONES ====================
print("\n" + "="*80)
