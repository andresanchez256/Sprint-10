    "axes[0,1].set_title('Ratio LTV/CAC por Fuente', fontsize=12, fontweight='bold')\\n",
    "axes[0,1].set_xlabel('Source ID')\\n",
    "axes[0,1].set_ylabel('LTV / CAC')\\n",
    "axes[0,1].axhline(1, color='red', linestyle='--', label='Punto equilibrio')\\n",
    "axes[0,1].axhline(3, color='green', linestyle='--', label='Excelente')\\n",
    "axes[0,1].legend()\\n",
    "\\n",
    "# Gasto vs Revenue\\n",
    "x = np.arange(len(summary_df.index))\\n",
    "width = 0.35\\n",
    "axes[1,0].bar(x - width/2, summary_df['Gasto($)'], width, label='Gasto', alpha=0.8)\\n",
    "axes[1,0].bar(x + width/2, summary_df['Revenue($)'], width, label='Revenue', alpha=0.8)\\n",
    "axes[1,0].set_title('Inversión vs Retorno', fontsize=12, fontweight='bold')\\n",
    "axes[1,0].set_xlabel('Source ID')\\n",
    "axes[1,0].set_ylabel('Monto ($)')\\n",
    "axes[1,0].set_xticks(x)\\n",
    "axes[1,0].set_xticklabels(summary_df.index.astype(str))\\n",
    "axes[1,0].legend()\\n",
    "\\n",
    "# CAC\\n",
    "axes[1,1].bar(summary_df.index.astype(str), summary_df['CAC($)'], color='coral')\\n",
    "axes[1,1].set_title('Costo de Adquisición (CAC)', fontsize=12, fontweight='bold')\\n",
    "axes[1,1].set_xlabel('Source ID')\\n",
    "axes[1,1].set_ylabel('CAC ($)')\\n",
    "axes[1,1].axhline(cac.mean(), color='blue', linestyle='--', label=f'Promedio: ${cac.mean():.2f}')\\n",
    "axes[1,1].legend()\\n",
    "\\n",
    "plt.tight_layout()\\n",
    "plt.show()"
   ]
  },
