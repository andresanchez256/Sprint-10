    "axes[0,1].plot(daily_sessions.index, daily_sessions.values, alpha=0.7, color='green', linewidth=1)\\n",
    "axes[0,1].set_title('Sesiones por Día', fontsize=12)\\n",
    "axes[0,1].set_xlabel('Fecha')\\n",
    "axes[0,1].set_ylabel('Número de Sesiones')\\n",
    "\\n",
    "# Usuarios por mes\\n",
    "axes[1,0].bar(monthly_users.index.astype(str), monthly_users.values)\\n",
