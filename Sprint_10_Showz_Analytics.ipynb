    "axes[1,1].set_title('Duración de Sesiones por Dispositivo', fontsize=12)\\n",
    "axes[1,1].set_xlabel('Dispositivo')\\n",
    "axes[1,1].set_ylabel('Duración (minutos)')\\n",
    "\\n",
    "plt.tight_layout()\\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Análisis de Ventas y LTV"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tiempo hasta primera compra\\n",
    "first_visit = visits_clean.groupby('Uid')['visit_date'].min().reset_index()\\n",
    "first_visit.columns = ['Uid', 'first_visit_date']\\n",
    "\\n",
    "first_purchase = orders_clean.groupby('Uid')['buy_date'].min().reset_index()\\n",
    "first_purchase.columns = ['Uid', 'first_purchase_date']\\n",
    "\\n",
    "user_journey = first_visit.merge(first_purchase, on='Uid', how='inner')\\n",
    "user_journey['first_visit_date'] = pd.to_datetime(user_journey['first_visit_date'])\\n",
    "user_journey['first_purchase_date'] = pd.to_datetime(user_journey['first_purchase_date'])\\n",
    "user_journey['days_to_purchase'] = (user_journey['first_purchase_date'] - user_journey['first_visit_date']).dt.days\\n",
    "\\n",
    "print(\\\"⏰ TIEMPO HASTA PRIMERA COMPRA:\\\")\\n",
    "print(f\\\"   Usuarios que compraron: {len(user_journey):,}\\\")\\n",
    "print(f\\\"   Días promedio: {user_journey['days_to_purchase'].mean():.1f}\\\")\\n",
    "print(f\\\"   Días mediana: {user_journey['days_to_purchase'].median():.0f}\\\")\\n",
    "\\n",
    "# Distribución de conversión\\n",
    "same_day = (user_journey['days_to_purchase'] == 0).sum()\\n",
    "one_day = (user_journey['days_to_purchase'] == 1).sum()\\n",
    "two_to_seven = ((user_journey['days_to_purchase'] >= 2) & (user_journey['days_to_purchase'] <= 7)).sum()\\n",
    "\\n",
    "print(f\\\"\\\\n📊 DISTRIBUCIÓN DE CONVERSIÓN:\\\")\\n",
    "print(f\\\"   Mismo día: {same_day} ({same_day/len(user_journey)*100:.1f}%)\\\")\\n",
    "print(f\\\"   1 día: {one_day} ({one_day/len(user_journey)*100:.1f}%)\\\")\\n",
    "print(f\\\"   2-7 días: {two_to_seven} ({two_to_seven/len(user_journey)*100:.1f}%)\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# LTV por usuario\\n",
    "user_revenue = orders_clean.groupby('Uid')['Revenue'].sum().reset_index()\\n",
    "user_revenue.columns = ['Uid', 'total_revenue']\\n",
    "\\n",
    "# LTV por fuente (primera visita)\\n",
    "first_source = visits_clean.sort_values('Start Ts').groupby('Uid').first().reset_index()[['Uid', 'Source Id']]\\n",
    "source_ltv = first_source.merge(user_revenue, on='Uid', how='left')\\n",
    "source_ltv['total_revenue'] = source_ltv['total_revenue'].fillna(0)\\n",
    "source_avg_ltv = source_ltv.groupby('Source Id')['total_revenue'].mean().sort_values(ascending=False)\\n",
    "\\n",
    "print(\\\"💰 LTV (LIFE TIME VALUE):\\\")\\n",
    "print(f\\\"   Promedio general: ${user_revenue['total_revenue'].mean():.2f}\\\")\\n",
    "print(f\\\"   Mediana: ${user_revenue['total_revenue'].median():.2f}\\\")\\n",
    "print(f\\\"\\\\n   LTV por fuente (top 3):\\\")\\n",
    "for source, ltv in source_avg_ltv.head(3).items():\\n",
    "    print(f\\\"   • Source {source}: ${ltv:.2f}\\\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Análisis de Marketing (CAC y ROMI)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clientes por fuente de adquisición\\n",
    "customers = orders_clean[['Uid']].drop_duplicates()\\n",
    "customers_by_source = first_source.merge(customers, on='Uid', how='inner')\\n",
    "new_customers = customers_by_source.groupby('Source Id').size()\\n",
    "\\n",
    "# Gastos por fuente\\n",
    "source_costs = costs_clean.groupby('source_id')['costs'].sum()\\n",
    "\\n",
    "# CAC\\n",
    "cac = source_costs / new_customers\\n",
    "\\n",
    "# Revenue por fuente\\n",
    "source_revenue = customers_by_source.merge(user_revenue, on='Uid', how='left')\\n",
    "source_revenue = source_revenue.groupby('Source Id')['total_revenue'].sum()\\n",
    "\\n",
    "# ROMI\\n",
    "romi = (source_revenue - source_costs) / source_costs * 100\\n",
    "\\n",
    "# Ratio LTV/CAC\\n",
    "ltv_ratio = (source_revenue / new_customers) / cac\\n",
    "\\n",
    "print(\\\"🎯 MÉTRICAS DE MARKETING:\\\")\\n",
    "print(f\\\"\\\\nCAC (Costo de Adquisición):\\\")\\n",
    "print(f\\\"   Promedio: ${(source_costs.sum() / len(customers)):.2f}\\\")\\n",
    "print(f\\\"\\\\nROMI (Retorno sobre inversión):\\\")\\n",
    "print(f\\\"   Promedio: {((source_revenue.sum() - source_costs.sum()) / source_costs.sum() * 100):.1f}%\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tabla resumen\\n",
    "summary_df = pd.DataFrame({\\n",
    "    'Gasto($)': source_costs,\\n",
    "    'Clientes': new_customers,\\n",
    "    'Revenue($)': source_revenue,\\n",
    "    'CAC($)': cac,\\n",
    "    'LTV($)': source_revenue / new_customers,\\n",
    "    'ROMI(%)': romi,\\n",
    "    'LTV/CAC': ltv_ratio\\n",
    "}).round(2)\\n",
    "\\n",
    "print(\\\"📊 RESUMEN POR FUENTE:\\\")\\n",
    "display(summary_df.sort_values('ROMI(%)', ascending=False))"
   ]
  },
  {
