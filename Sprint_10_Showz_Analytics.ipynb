def create_visualizations(summary, romi_by_source, ltv_cac_ratio):
    """Crea visualizaciones clave"""
    
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    
    # 1. ROMI por fuente
    colors = ['green' if x > 0 else 'red' for x in romi_by_source.values]
    axes[0,0].bar(romi_by_source.index.astype(str), romi_by_source.values, color=colors)
    axes[0,0].set_title('ROMI por Fuente de Adquisición', fontsize=12, fontweight='bold')
    axes[0,0].set_xlabel('Source ID')
    axes[0,0].set_ylabel('ROMI (%)')
    axes[0,0].axhline(0, color='black', linestyle='-', linewidth=1)
    axes[0,0].axhline(20, color='green', linestyle='--', alpha=0.5, label='Objetivo mínimo (20%)')
    axes[0,0].legend()
    
    # 2. LTV/CAC Ratio
    bars = axes[0,1].bar(ltv_cac_ratio.index.astype(str), ltv_cac_ratio.values)
    axes[0,1].set_title('Ratio LTV/CAC por Fuente', fontsize=12, fontweight='bold')
    axes[0,1].set_xlabel('Source ID')
    axes[0,1].set_ylabel('LTV / CAC')
    axes[0,1].axhline(1, color='red', linestyle='--', label='Punto de equilibrio')
    axes[0,1].axhline(3, color='green', linestyle='--', label='Excelente (>3)')
    axes[0,1].legend()
    
    # 3. Comparación Gasto vs Revenue
    x = np.arange(len(summary.index))
    width = 0.35
    axes[1,0].bar(x - width/2, summary['Gasto_Total'], width, label='Gasto', alpha=0.8)
    axes[1,0].bar(x + width/2, summary['Revenue_Total'], width, label='Revenue', alpha=0.8)
    axes[1,0].set_title('Inversión vs Retorno por Fuente', fontsize=12, fontweight='bold')
    axes[1,0].set_xlabel('Source ID')
    axes[1,0].set_ylabel('Monto ($)')
    axes[1,0].set_xticks(x)
    axes[1,0].set_xticklabels(summary.index.astype(str))
    axes[1,0].legend()
    
    # 4. CAC por fuente
    axes[1,1].bar(summary.index.astype(str), summary['CAC'], color='coral')
    axes[1,1].set_title('Costo de Adquisición por Cliente (CAC)', fontsize=12, fontweight='bold')
    axes[1,1].set_xlabel('Source ID')
    axes[1,1].set_ylabel('CAC ($)')
    axes[1,1].axhline(summary['CAC'].mean(), color='blue', linestyle='--', 
                      label=f'Promedio: ${summary["CAC"].mean():.2f}')
    axes[1,1].legend()
    
    plt.tight_layout()
    plt.savefig('marketing_analysis_summary.png', dpi=300, bbox_inches='tight')
    plt.show()
    
    print("   ✓ Visualizaciones guardadas como 'marketing_analysis_summary.png'")

create_visualizations(summary, romi_by_source, ltv_cac_ratio)

