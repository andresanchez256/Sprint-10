    "warnings.filterwarnings('ignore')\\n",
    "\\n",
    "# Configuración\\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\\n",
    "sns.set_palette(\\\"Set2\\\")\\n",
    "pd.set_option('display.max_columns', None)\\n",
    "pd.set_option('display.float_format', lambda x: '%.2f' % x)\\n",
    "\\n",
    "print(\\\"✅ Librerías cargadas\\\")\\n",
    "print(f\\\"Pandas version: {pd.__version__}\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar datos\\n",
    "visits = pd.read_csv('/datasets/visits_log_us.csv')\\n",
    "orders = pd.read_csv('/datasets/orders_log_us.csv')\\n",
    "costs = pd.read_csv('/datasets/costs_us.csv')\\n",
    "\\n",
    "print(\\\"📊 Datos cargados:\\\")\\n",
    "print(f\\\"   Visits: {visits.shape[0]:,} registros\\\")\\n",
    "print(f\\\"   Orders: {orders.shape[0]:,} registros\\\")\\n",
    "print(f\\\"   Costs: {costs.shape[0]:,} registros\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Limpieza de Visits\\n",
    "visits_clean = visits.copy()\\n",
    "\\n",
    "# Convertir fechas\\n",
    "visits_clean['Start Ts'] = pd.to_datetime(visits_clean['Start Ts'])\\n",
    "visits_clean['End Ts'] = pd.to_datetime(visits_clean['End Ts'])\\n",
    "\\n",
    "# Calcular duración (minutos)\\n",
    "visits_clean['duration_min'] = (visits_clean['End Ts'] - visits_clean['Start Ts']).dt.total_seconds() / 60\\n",
    "\\n",
    "# Eliminar sesiones inválidas\\n",
    "invalid = (visits_clean['duration_min'] < 0) | (visits_clean['duration_min'] > 1440)\\n",
    "print(f\\\"Sesiones inválidas eliminadas: {invalid.sum()} ({invalid.sum()/len(visits_clean)*100:.2f}%)\\\")\\n",
    "visits_clean = visits_clean[~invalid]\\n",
    "\\n",
    "# Columnas temporales\\n",
    "visits_clean['visit_date'] = visits_clean['Start Ts'].dt.date\\n",
    "visits_clean['visit_month'] = visits_clean['Start Ts'].dt.to_period('M')\\n",
    "visits_clean['visit_week'] = visits_clean['Start Ts'].dt.to_period('W')\\n",
    "visits_clean['visit_hour'] = visits_clean['Start Ts'].dt.hour\\n",
    "\\n",
    "print(f\\\"\\\\n✅ Visits limpios: {len(visits_clean):,} filas\\\")\\n",
    "print(f\\\"   Usuarios únicos: {visits_clean['Uid'].nunique():,}\\\")\\n",
    "print(f\\\"   Rango: {visits_clean['visit_date'].min()} a {visits_clean['visit_date'].max()}\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Limpieza de Orders\\n",
    "orders_clean = orders.copy()\\n",
    "orders_clean['Buy Ts'] = pd.to_datetime(orders_clean['Buy Ts'])\\n",
    "orders_clean['buy_date'] = orders_clean['Buy Ts'].dt.date\\n",
    "orders_clean['buy_month'] = orders_clean['Buy Ts'].dt.to_period('M')\\n",
    "orders_clean['buy_year_month'] = orders_clean['Buy Ts'].dt.strftime('%Y-%m')\\n",
    "\\n",
    "# Limpieza de Costs\\n",
    "costs_clean = costs.copy()\\n",
    "costs_clean['dt'] = pd.to_datetime(costs_clean['dt'])\\n",
    "costs_clean['cost_date'] = costs_clean['dt'].dt.date\\n",
    "costs_clean['cost_month'] = costs_clean['dt'].dt.to_period('M')\\n",
    "costs_clean['cost_year_month'] = costs_clean['dt'].dt.strftime('%Y-%m')\\n",
    "\\n",
    "print(f\\\"✅ Orders: {len(orders_clean):,} pedidos\\\")\\n",
    "print(f\\\"   Revenue total: ${orders_clean['Revenue'].sum():,.2f}\\\")\\n",
    "print(f\\\"   Revenue promedio: ${orders_clean['Revenue'].mean():.2f}\\\")\\n",
    "print(f\\\"\\\\n✅ Costs: {len(costs_clean):,} registros\\\")\\n",
    "print(f\\\"   Gasto total: ${costs_clean['costs'].sum():,.2f}\\\")\\n",
    "print(f\\\"   Fuentes: {sorted(costs_clean['source_id'].unique())}\\\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Análisis de Visitas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Usuarios activos\\n",
    "daily_users = visits_clean.groupby('visit_date')['Uid'].nunique()\\n",
    "weekly_users = visits_clean.groupby('visit_week')['Uid'].nunique()\\n",
    "monthly_users = visits_clean.groupby('visit_month')['Uid'].nunique()\\n",
    "daily_sessions = visits_clean.groupby('visit_date').size()\\n",
    "\\n",
    "print(\\\"📈 USUARIOS ACTIVOS:\\\")\\n",
    "print(f\\\"   Promedio diario: {daily_users.mean():.0f}\\\")\\n",
    "print(f\\\"   Promedio semanal: {weekly_users.mean():.0f}\\\")\\n",
    "print(f\\\"   Promedio mensual: {monthly_users.mean():.0f}\\\")\\n",
    "print(f\\\"   Sesiones promedio/día: {daily_sessions.mean():.0f}\\\")\\n",
    "\\n",
    "# Duración de sesiones\\n",
    "print(f\\\"\\\\n⏱️ DURACIÓN DE SESIONES:\\\")\\n",
    "print(f\\\"   Promedio: {visits_clean['duration_min'].mean():.1f} minutos\\\")\\n",
    "print(f\\\"   Mediana: {visits_clean['duration_min'].median():.1f} minutos\\\")\\n",
    "print(f\\\"   Máxima: {visits_clean['duration_min'].max():.1f} minutos\\\")\\n",
    "\\n",
    "# Frecuencia de retorno\\n",
    "user_session_count = visits_clean.groupby('Uid').size()\\n",
    "returning_users = (user_session_count > 1).sum()\\n",
    "pct_returning = (returning_users / len(user_session_count)) * 100\\n",
    "\\n",
    "print(f\\\"\\\\n🔄 RETORNO DE USUARIOS:\\\")\\n",
    "print(f\\\"   Usuarios que regresan: {returning_users:,} ({pct_returning:.1f}%)\\\")\\n",
    "print(f\\\"   Sesiones promedio por usuario: {user_session_count.mean():.2f}\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualización de visitas\\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\\n",
    "\\n",
    "# Usuarios diarios\\n",
    "axes[0,0].plot(daily_users.index, daily_users.values, alpha=0.7, linewidth=1)\\n",
